# Ignore all dotfiles/folders by default
.*

# Exceptions for essential project config
!.gitignore
!**/.dockerignore
!**/.env.example
!**/.gitkeep

# Pre-commit and CI config (track these)
!.pre-commit-config.yaml
!.gitleaks.toml
!.github/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
