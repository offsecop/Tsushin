frontend/lib/*.backup
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Environment variables
.env
.env.local
.env.production
*.env

# Database files
*.db
*.sqlite
*.sqlite3
backend/data/*.db
backend/data/chroma/

# Logs
*.log
logs/
backend/logs/

# Process ID files
*.pid
ops/.pids/

