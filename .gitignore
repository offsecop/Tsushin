**/messages.db
**/whatsapp.db
**/store/messages.db
**/store/whatsapp.db
backend/ops/qa/*/whatsapp-bridge/store/
backend/ops/qa/vini_mcp/whatsapp-bridge/store/*.db

# OS
Thumbs.db
.DS_Store

