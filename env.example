# ============================================================================
# Tsushin Environment Configuration
#
# Copy this file to .env and configure the values for your environment.
# The installer (python3 install.py) generates this file automatically.
# ============================================================================

# ----------------------------------------------------------------------------
# Application Configuration
# ----------------------------------------------------------------------------

# Backend host and port
TSN_APP_HOST=0.0.0.0
TSN_APP_PORT=8081

# URL Configuration (for OAuth callbacks, redirects, CORS)
# In production, set these to your actual domain URLs
TSN_BACKEND_URL=http://localhost:8081
TSN_FRONTEND_URL=http://localhost:3030

# Log level (DEBUG, INFO, WARNING, ERROR)
TSN_LOG_LEVEL=INFO
TSN_LOG_FILE=/app/logs/tsushin.log
# TSN_LOG_FORMAT=text          # text (default) | json (structured, for GKE/Cloud Logging)

# Observability
# TSN_METRICS_ENABLED=true     # Enable Prometheus metrics at /metrics (default: true)

# MCP Watcher polling interval (milliseconds)
TSN_POLL_INTERVAL_MS=3000

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------

# PostgreSQL password (REQUIRED — docker-compose will refuse to start without this)
# Generate a secure password: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=

# Internal SQLite database path (legacy, kept for MCP reader)
INTERNAL_DB_PATH=/app/data/agent.db

# ChromaDB vector store directory
TSN_CHROMA_DIR=/app/data/chroma

# Custom tools workspace directory
TSN_WORKSPACE_DIR=/app/data/workspace

# Database backups directory
TSN_BACKUPS_DIR=/app/data/backups

# ----------------------------------------------------------------------------
# Security Configuration (REQUIRED)
# ----------------------------------------------------------------------------

# JWT Secret Key for authentication
# IMPORTANT: Generate a secure random key for production!
# Run: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# Encryption key for Hub integration OAuth tokens (Asana, etc.)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Note: Google/SSO encryption keys are auto-generated and stored in the database.
ASANA_ENCRYPTION_KEY=

# ----------------------------------------------------------------------------
# AI Provider API Keys (Optional — env var fallback)
#
# These keys are passed to the container as fallback. The PRIMARY way to
# configure AI providers is via the UI (Settings > Integrations) or the
# setup-wizard API, which stores keys encrypted in the database.
# Env vars are only used when no DB key is found for a provider.
# ----------------------------------------------------------------------------

GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# GROK_API_KEY=
# DEEPSEEK_API_KEY=
# ELEVENLABS_API_KEY=

# Ollama (Local LLM - optional, host-network access)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ----------------------------------------------------------------------------
# Integration Callback URIs
# ----------------------------------------------------------------------------

# Google OAuth callback (for Gmail/Calendar Hub integrations)
TSN_GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8081/api/hub/google/oauth/callback

# Asana OAuth callback
ASANA_REDIRECT_URI=http://localhost:3030/hub/asana/callback

# ----------------------------------------------------------------------------
# Google SSO Configuration (Optional — platform-wide)
# Per-tenant SSO is configured via UI: Settings > Integrations + Settings > Security
# These env vars are only needed for platform-wide SSO (all tenants share one Google app)
# ----------------------------------------------------------------------------

# TSN_GOOGLE_SSO_CLIENT_ID=
# TSN_GOOGLE_SSO_CLIENT_SECRET=
# TSN_GOOGLE_SSO_REDIRECT_URI=http://localhost:8081/api/auth/google/callback

# ----------------------------------------------------------------------------
# External Services (Optional)
# ----------------------------------------------------------------------------

# Kokoro TTS Service URL (free voice synthesis)
KOKORO_SERVICE_URL=http://host.docker.internal:8880

# Tool API keys (only if using these specific agent tools)
# BRAVE_API=
# AMADEUS_API_KEY=
# AMADEUS_API_SECRET=

# ----------------------------------------------------------------------------
# Container Runtime Configuration
# ----------------------------------------------------------------------------

# Container orchestration backend: docker (default) or kubernetes (GKE)
TSN_CONTAINER_RUNTIME=docker

# Secret backend: env (default, reads from environment) or gcp (Google Secret Manager)
TSN_SECRET_BACKEND=env

# GCP Secret Manager (when TSN_SECRET_BACKEND=gcp)
# TSN_GCP_PROJECT_ID=your-gcp-project-id
# TSN_GCP_SECRET_PREFIX=tsushin
# TSN_GCP_SECRET_CACHE_TTL=300
# TSN_GCP_SECRET_VERSION=latest

# Kubernetes Runtime (when TSN_CONTAINER_RUNTIME=kubernetes)
# TSN_K8S_NAMESPACE=tsushin                    # K8s namespace for MCP/toolbox pods
# TSN_K8S_IMAGE_PULL_POLICY=IfNotPresent       # IfNotPresent | Always

# ----------------------------------------------------------------------------
# Docker-Specific Configuration
# ----------------------------------------------------------------------------

# CRITICAL: Host path for MCP container volume mounts (Docker-in-Docker)
# This MUST be set to the absolute path of backend/data on your HOST machine.
# The installer (python3 install.py) sets this automatically.
# Example for Linux: /home/user/tsushin/backend/data
# Example for macOS: /Users/user/tsushin/backend/data
# Example for Windows: C:\Users\user\tsushin\backend\data
HOST_BACKEND_DATA_PATH=

# ----------------------------------------------------------------------------
# SSL/HTTPS Configuration (Caddy Reverse Proxy)
# ----------------------------------------------------------------------------

# SSL mode: disabled (default), letsencrypt, manual, selfsigned
SSL_MODE=disabled

# Domain name for SSL certificate (required when SSL_MODE != disabled)
SSL_DOMAIN=

# Email for Let's Encrypt notifications (required for letsencrypt mode)
SSL_EMAIL=

# Ports for the reverse proxy (only used when SSL_MODE != disabled)
HTTP_PORT=80
HTTPS_PORT=443

# ----------------------------------------------------------------------------
# Frontend Configuration
# ----------------------------------------------------------------------------

# Next.js public API URL (baked at build time)
NEXT_PUBLIC_API_URL=http://localhost:8081

# Development mode (shows test user quick-login on login page)
# NEXT_PUBLIC_DEV_MODE=true
