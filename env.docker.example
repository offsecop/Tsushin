# ============================================================================
# Tsushin Docker Environment Configuration
#
# Minimal env template for Docker deployments.
# For the full reference with all options, see env.example.
# The installer (python3 install.py) generates .env automatically.
# ============================================================================

# Application
TSN_APP_HOST=0.0.0.0
TSN_APP_PORT=8081
TSN_BACKEND_URL=http://localhost:8081
TSN_FRONTEND_URL=http://localhost:3030

# PostgreSQL (REQUIRED — docker-compose will refuse to start without this)
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=

# Security (REQUIRED)
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# Encryption key for Hub OAuth tokens
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ASANA_ENCRYPTION_KEY=

# AI Provider API Keys (env var fallback — primary config is via UI)
# The setup wizard stores these in the database on first install.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Logging
TSN_LOG_LEVEL=INFO

# MCP Watcher
TSN_POLL_INTERVAL_MS=3000

# Docker-in-Docker: Host path for MCP container volume mounts (REQUIRED)
# Must be the absolute path to backend/data on the HOST machine
HOST_BACKEND_DATA_PATH=

# SSL/HTTPS (Caddy Reverse Proxy)
# Modes: disabled (default), letsencrypt, manual, selfsigned
SSL_MODE=disabled
# SSL_DOMAIN=
# SSL_EMAIL=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8081
# NEXT_PUBLIC_DEV_MODE=true

# Container Runtime
TSN_CONTAINER_RUNTIME=docker
TSN_SECRET_BACKEND=env

# CORS (default allows all — restrict in production)
# TSN_CORS_ORIGINS=https://app.example.com
