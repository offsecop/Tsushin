# Docker Environment Configuration for Tsushin
# Copy this file to .env.docker and fill in your values

# Application
APP_HOST=0.0.0.0
APP_PORT=8081

# PostgreSQL Database (REQUIRED — docker-compose will refuse to start without this)
# Generate a secure password: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=your_secure_password_here
# DATABASE_URL is auto-configured in docker-compose.yml; override here if needed:
# DATABASE_URL=postgresql+asyncpg://tsushin:your_secure_password_here@tsushin-postgres:5432/tsushin

# Legacy SQLite path (kept for MCP reader and dev fallback)
INTERNAL_DB_PATH=/app/data/agent.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/tsushin.log

# MCP Configuration
POLL_INTERVAL_MS=3000
MAX_MESSAGES_PER_POLL=500

# Memory
DEFAULT_MEMORY_SIZE=10
MAX_MEMORY_SIZE=50

# AI Provider
PROVIDER=anthropic
MODEL_NAME=claude-sonnet-4-20250514

# API Keys (fill in your values)
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=
GROK_API_KEY=
ELEVENLABS_API_KEY=
BRAVE_API=your-brave-api-key
JWT_SECRET_KEY=your-jwt-secret-key

# SSL/HTTPS Configuration (Caddy Reverse Proxy)
# Modes: disabled (default), letsencrypt, manual, selfsigned
SSL_MODE=disabled
# Domain name for SSL certificate (required when SSL_MODE != disabled)
SSL_DOMAIN=
# Email for Let's Encrypt notifications (required for letsencrypt mode)
SSL_EMAIL=
# Ports for the reverse proxy (only used when SSL_MODE != disabled)
HTTP_PORT=80
HTTPS_PORT=443

# Container Runtime Configuration
# Container orchestration backend: docker (default) or kubernetes (GKE)
TSN_CONTAINER_RUNTIME=docker
# Secret backend: env (default) or gcp (Google Secret Manager)
TSN_SECRET_BACKEND=env

# GCP Secret Manager (when TSN_SECRET_BACKEND=gcp)
# TSN_GCP_PROJECT_ID=your-gcp-project-id
# TSN_GCP_SECRET_PREFIX=tsushin
# TSN_GCP_SECRET_CACHE_TTL=300
# TSN_GCP_SECRET_VERSION=latest

# CORS Allowed Origins
# Default: * (allow all origins — suitable for development)
# For production, set to a comma-separated list of allowed origins:
# TSN_CORS_ORIGINS=https://app.example.com,https://admin.example.com
TSN_CORS_ORIGINS=*

# Frontend API URL (for Docker network)
NEXT_PUBLIC_API_URL=http://tsushin-backend:8081

# Development Mode (set to 'true' to show test user quick-login on login page)
# Set to 'false' or remove in production
NEXT_PUBLIC_DEV_MODE=true
