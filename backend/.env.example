# ============================================================================
# Tsushin Backend — Local Development Environment
#
# For local dev (non-Docker). Docker deployments use the root .env file.
# Integration API keys are managed via UI/DB, not env vars.
# ============================================================================

# Application
TSN_APP_HOST=127.0.0.1
TSN_APP_PORT=8081

# Database
TSN_INTERNAL_DB_PATH=./data/agent.db

# Logging
TSN_LOG_FILE=logs/tsushin.log
TSN_LOG_LEVEL=INFO

# MCP Watcher
TSN_POLL_INTERVAL_MS=3000

# Authentication (REQUIRED)
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# Hub OAuth encryption
ASANA_ENCRYPTION_KEY=
ASANA_REDIRECT_URI=http://localhost:3030/hub/asana/callback

# External service URLs
# NOTE: KOKORO_SERVICE_URL was removed in v0.7.0. Kokoro TTS is now
# auto-provisioned per tenant via Hub → Kokoro TTS → Setup with Wizard.

# Container Runtime
TSN_CONTAINER_RUNTIME=docker
TSN_SECRET_BACKEND=env
