# ============================================================================
# Tsushin Backend Environment Variables
#
# For local development (non-Docker). Docker deployments use the root .env file.
# All variables use TSN_ prefix for consistency (legacy names still supported).
# ============================================================================

# Application Configuration
TSN_APP_HOST=127.0.0.1
TSN_APP_PORT=8081

# Database Paths
TSN_INTERNAL_DB_PATH=./data/agent.db
# TSN_WORKSPACE_DIR=./data/workspace
# TSN_CHROMA_DIR=./data/chroma
# TSN_BACKUPS_DIR=./data/backups

# Logging
TSN_LOG_FILE=logs/tsushin.log
TSN_LOG_LEVEL=INFO
# TSN_LOG_FORMAT=text          # text (default) | json (structured, for GKE/Cloud Logging)

# Observability
# TSN_METRICS_ENABLED=true     # Enable Prometheus metrics at /metrics (default: true)

# MCP Watcher
TSN_POLL_INTERVAL_MS=3000

# Authentication (REQUIRED for production)
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# AI Provider API Keys (env var fallback — primary config is via UI/DB)
# These are only used when no key is found in the database for the provider.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# GROK_API_KEY=
# DEEPSEEK_API_KEY=
# ELEVENLABS_API_KEY=

# Hub Integration — Asana OAuth Token Encryption
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ASANA_ENCRYPTION_KEY=
ASANA_REDIRECT_URI=http://localhost:3030/hub/asana/callback

# Google SSO (Optional — platform-wide; per-tenant SSO configured via UI)
# TSN_GOOGLE_SSO_CLIENT_ID=
# TSN_GOOGLE_SSO_CLIENT_SECRET=
# TSN_GOOGLE_SSO_REDIRECT_URI=http://localhost:8081/api/auth/google/callback

# Kokoro TTS Service (Optional)
KOKORO_SERVICE_URL=http://localhost:8880

# Ollama (Local LLM - optional)
OLLAMA_BASE_URL=http://localhost:11434

# Container Runtime (for local dev, always docker)
TSN_CONTAINER_RUNTIME=docker
TSN_SECRET_BACKEND=env
